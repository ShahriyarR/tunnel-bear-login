es] = useState<BearImages>({\n    watchImages: [],\n    hideImages: [],\n    peakImages: [],\n  });\n\n  useEffect(() => {\n    type ImageModule = { default: string };\n    \n    // Load bear images (existing)\n    const loadBearImages = async () => {\n      try {\n        const watchImages = import.meta.glob<ImageModule>(\"/src/assets/img/watch_bear_*.png\", { eager: true });\n        const hideImages = import.meta.glob<ImageModule>(\"/src/assets/img/hide_bear_*.png\", { eager: true });\n        const peakImages = import.meta.glob<ImageModule>(\"/src/assets/img/peak_bear_*.png\", { eager: true });\n        \n        const sortImages = (images: Record<string, ImageModule>) => {\n          return Object.values(images)\n            .map(img => img.default)\n            .sort((a, b) => {\n              const aNum = parseInt(a.match(/\\d+/)?.[0] || \"0\");\n              const bNum = parseInt(b.match(/\\d+/)?.[0] || \"0\");\n              return aNum - bNum;\n            });\n        };\n        \n        setBearImages({\n          watchImages: sortImages(watchImages).map(img => img),\n          hideImages: sortImages(hideImages).map(img => img),\n          peakImages: sortImages(peakImages).map(img => img),\n        });\n      } catch (error) {\n        console.warn('Failed to load bear images:', error);\n      }\n    };\n\n    // Load dog images (will fail initially - expected)\n    const loadDogImages = async () => {\n      try {\n        const watchImages = import.meta.glob<ImageModule>(\"/src/assets/img/watch_dog_*.png\", { eager: true });\n        const hideImages = import.meta.glob<ImageModule>(\"/src/assets/img/hide_dog_*.png\", { eager: true });\n        const peakImages = import.meta.glob<ImageModule>(\"/src/assets/img/peak_dog_*.png\", { eager: true });\n        \n        const sortImages = (images: Record<string, ImageModule>) => {\n          return Object.values(images)\n            .map(img => img.default)\n            .sort((a, b) => {\n              cons